# ── App URLs ──────────────────────────────────────────────
NEXT_PUBLIC_SAAS_LOGIN_URL=https://app.assps.edu.pk/login
NEXT_PUBLIC_API_URL=/api

# ── Database (optional — file fallback when unset) ────────
DATABASE_URL=postgresql://user:pass@localhost:5432/apex

# ── SMTP (subscription + lead emails) ─────────────────────
SMTP_HOST=smtp.yourmailhost.com
SMTP_PORT=587
SMTP_USER=your_email_user
SMTP_PASS=your_email_password
SMTP_FROM="APEX Support <support@yourdomain.com>"
APEX_LEADS_NOTIFY_EMAIL=admin@yourdomain.com

# ── Admin auth (required in production) ───────────────────
SAAS_ADMIN_USER=your_admin_username
SAAS_ADMIN_PASS=your_strong_password

# ── JazzCash (sandbox or production) ──────────────────────
JAZZCASH_ENV=sandbox
JAZZCASH_MERCHANT_ID=
JAZZCASH_PASSWORD=
JAZZCASH_INTEGRITY_SALT=
JAZZCASH_RETURN_URL=https://apex.assps.edu.pk/api/payment/jazzcash/callback
NEXT_PUBLIC_APEX_URL=https://apex.assps.edu.pk

# ── Bank transfer (server-side preferred; NEXT_PUBLIC_ fallback) ─
APEX_BANK_NAME=Meezan Bank
APEX_BANK_ACCOUNT_TITLE=AL SIDDIQUE SCHOLARS PUBLIC SCHOOL
APEX_BANK_ACCOUNT=
APEX_BANK_IBAN=
APEX_BANK_BRANCH=Lahore

# ── Deploy script (local machine — do not commit real password) ─
APEX_DEPLOY_HOST=72.61.228.88
APEX_DEPLOY_USER=root
APEX_DEPLOY_PASSWORD=
# JAZZCASH_ENDPOINT=  # override default sandbox/production URL
# JAZZCASH_SUCCESS_CODE=000

# ── EasyPaisa (sandbox or production) ─────────────────────
EASYPAISA_ENV=sandbox
EASYPAISA_STORE_ID=
EASYPAISA_HASH_KEY=
EASYPAISA_RETURN_URL=https://apex.assps.edu.pk/api/payment/easypaisa/callback
# EASYPAISA_SUCCESS_STATUS=0000,SUCCESS,PAID
# EASYPAISA_SKIP_HASH_VERIFY=true  # sandbox only

# ── Payment / lead admin notifications ──────────────────────
APEX_PAYMENTS_NOTIFY_EMAIL=admin@yourdomain.com
# Auto-activate school tenant after JazzCash/EasyPaisa payment (requires DB)
APEX_AUTO_APPROVE_GATEWAY_PAYMENTS=false

# ── Stripe (card checkout) ────────────────────────────────
STRIPE_SECRET_KEY=
STRIPE_PUBLISHABLE_KEY=
NEXT_PUBLIC_STRIPE_PUBLISHABLE_KEY=
STRIPE_CURRENCY=pkr
# Webhook endpoint: https://apex.assps.edu.pk/api/payment/stripe/webhook
# Stripe Dashboard → Developers → Webhooks → checkout.session.completed
STRIPE_WEBHOOK_SECRET=

# ── Analytics (optional) ──────────────────────────────────
NEXT_PUBLIC_GA_MEASUREMENT_ID=
